generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PromptTelemetry {
  id              String   @id @default(cuid())
  userId          String?
  originalLength  Int
  rewrittenLength Int
  strategyUsed    String
  toneUsed        String?
  scoreBefore     Int
  scoreAfter      Int
  createdAt       DateTime @default(now())
}
